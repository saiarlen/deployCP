APP_NAME=DeployCP
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8080
APP_BASE_URL=http://localhost:8080
APP_VERSION=
DEPLOYCP_REPO=saiarlen/deployCP

SQLITE_PATH=./storage/db/deploycp.sqlite

SESSION_SECRET=change-this-session-secret-to-at-least-32-characters
SESSION_COOKIE_NAME=deploycp_session
SESSION_SECURE_COOKIES=false
CSRF_ENABLED=true
LOGIN_RATE_LIMIT_PER_MIN=20

BOOTSTRAP_ADMIN_USERNAME=admin
BOOTSTRAP_ADMIN_EMAIL=admin@localhost
BOOTSTRAP_ADMIN_PASSWORD=admin123!ChangeNow

STORAGE_ROOT=./storage
DEFAULT_SITE_ROOT=./storage/sites
LOG_ROOT=./storage/logs
RUNTIME_ROOT=./storage/runtimes
HTPASSWD_ROOT=./storage/generated/htpasswd
CRON_DIR=/etc/cron.d

NGINX_BINARY=/usr/sbin/nginx
NGINX_CONFIG_DIR=/etc/nginx
NGINX_ENABLED_DIR=/etc/nginx/sites-enabled
NGINX_AVAILABLE_DIR=/etc/nginx/sites-available
SYSTEMCTL_BINARY=/bin/systemctl
LAUNCHCTL_BINARY=/bin/launchctl
LAUNCHD_PLIST_DIR=/Library/LaunchDaemons
RESTRICTED_SHELL_PATH=/usr/local/bin/deploycp-rshell
RUNUSER_BINARY=/usr/sbin/runuser
CERTBOT_BINARY=/usr/bin/certbot
UFW_BINARY=/usr/sbin/ufw
FIREWALLCMD_BINARY=/usr/bin/firewall-cmd
IPTABLES_BINARY=/usr/sbin/iptables

ADMINER_URL=http://127.0.0.1:8081
POSTGRES_GUI_URL=http://127.0.0.1:8082
REDIS_INFO_TIMEOUT_SEC=3

FEATURE_SERVICE_MANAGE=true
FEATURE_NGINX_MANAGE=true
MARIADB_ADMIN_USER=
MARIADB_ADMIN_PASSWORD=
MARIADB_ADMIN_HOST=127.0.0.1
MARIADB_ADMIN_PORT=3306
POSTGRES_ADMIN_USER=
POSTGRES_ADMIN_PASSWORD=
POSTGRES_ADMIN_HOST=127.0.0.1
POSTGRES_ADMIN_PORT=5432
POSTGRES_ADMIN_DB=postgres
FTP_NOLOGIN_SHELL=/usr/sbin/nologin
PROFTPD_CONF_DIR=/etc/proftpd/conf.d
PROFTPD_SERVICE_NAME=proftpd
REDIS_SERVER_BINARY=/usr/bin/redis-server
VARNISH_CONFIG_DIR=/etc/varnish/deploycp.d
VARNISH_SERVICE_NAME=varnish
VARNISH_MAIN_VCL=/etc/varnish/default.vcl
VARNISH_INCLUDE_VCL=/etc/varnish/deploycp.d/deploycp.vcl
VARNISHD_BINARY=/usr/sbin/varnishd

# Platform mode: "auto" uses real OS commands (darwin/linux), "dryrun" simulates everything.
# Use dryrun for local development on macOS when you don't have nginx/systemd.
PLATFORM_MODE=dryrun
